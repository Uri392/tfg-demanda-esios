from pathlib import Path
import sys
import numpy as np
import pandas as pd
import matplotlib.pyplot as plt


# =============================================================================
# CONFIGURACIÓN
# =============================================================================

LOCAL_TZ = "Europe/Madrid"

# Este es el CSV correcto: el de predicciones del mejor modelo por estación.
# Evitamos que el script coja automáticamente el CSV de "all_models".
PROJECT_ROOT = Path(__file__).resolve().parents[2]

PREDICTIONS_CSV = (
    PROJECT_ROOT
    / "outputs/modeling/gam_seasonal_clean/22_test_predictions_best_model_by_season.csv"
)

OUT_DIR = PROJECT_ROOT / "outputs/modeling/gam_observed_vs_predicted"
