def plot_monthly_observed_vs_predicted(predictions):
    monthly = (
        predictions
        .groupby(["season", "local_year", "local_month"], as_index=False)
        .agg(
            observed_mean_mw=("demand_mw", "mean"),
            predicted_gam_mean_mw=("pred_gam_mw", "mean"),
        )
    )

    monthly["year_month"] = (
        monthly["local_year"].astype(str)
        + "-"
        + monthly["local_month"].astype(str).str.zfill(2)
    )

    for season in ["DJF", "MAM", "JJA", "SON"]:
        season_monthly = monthly[monthly["season"] == season].copy()

        if season_monthly.empty:
            continue

        fig, ax = plt.subplots(figsize=(11, 5))

        ax.plot(
            season_monthly["year_month"],
            season_monthly["observed_mean_mw"],
            marker="o",
            label="Observado"
        )

        ax.plot(
            season_monthly["year_month"],
            season_monthly["predicted_gam_mean_mw"],
            marker="o",
            label="Predicho GAM"
        )

        ax.set_title(f"{season} test 2021-2025: demanda observada vs predicha")
        ax.set_xlabel("Mes")
        ax.set_ylabel("Demanda media (MW)")
        ax.grid(True, alpha=0.25)
        ax.legend()
        plt.xticks(rotation=45, ha="right")
        plt.tight_layout()

        out_path = PLOT_DIR / f"03_monthly_observed_vs_predicted_{season}.png"
        plt.savefig(out_path, dpi=150)
        plt.close()

        print(f"Gráfico guardado: {out_path}")


def main():
    df = load_data()
    print(f"Filas leídas totales: {len(df):,}")

    df = add_calendar_features(df)

    all_metrics = []
    all_deltas = []
    all_predictions = []

    for season in ["DJF", "MAM", "JJA", "SON"]:
        metrics, delta, predictions = analyze_one_season(df, season)

        if metrics is not None:
            all_metrics.append(metrics)
            all_deltas.append(delta)
            all_predictions.append(predictions)

    comparison = pd.concat(all_metrics, ignore_index=True)
    deltas = pd.concat(all_deltas, ignore_index=True)
    predictions = pd.concat(all_predictions, ignore_index=True)

    comparison_path = OUT_DIR / "season_model_comparison.csv"
    deltas_path = OUT_DIR / "season_gam_vs_baseline_deltas.csv"
    predictions_path = OUT_DIR / "season_test_predictions.csv"

    comparison.to_csv(comparison_path, index=False)
    deltas.to_csv(deltas_path, index=False)
    predictions.to_csv(predictions_path, index=False)

    print("\n" + "=" * 90)
    print("RESUMEN GLOBAL POR ESTACIÓN")
    print("=" * 90)
    print(comparison.to_string(index=False))

    print("\n" + "=" * 90)
    print("MEJORA DEL GAM RESPECTO AL MODELO BASE")
    print("=" * 90)
    print(deltas.to_string(index=False))

    plot_rmse_by_season(comparison)
    plot_r2_by_season(comparison)
    plot_monthly_observed_vs_predicted(predictions)

    print("\nArchivos generados:")
    print(f"- Comparación modelos: {comparison_path}")
    print(f"- Mejoras GAM vs base: {deltas_path}")
    print(f"- Predicciones test: {predictions_path}")
    print(f"- Gráficos: {PLOT_DIR}")


if __name__ == "__main__":
    main()