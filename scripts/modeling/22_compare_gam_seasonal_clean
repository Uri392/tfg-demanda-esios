# SCRIPT PRINCIPAL
# ============================================================

def main():
    df = load_data()
    df = add_calendar_features(df)
    df = add_thermal_inertia_features(df)

    print("\nRango temporal:")
    print(f"- Inicio UTC: {df['timestamp_utc'].min()}")
    print(f"- Fin UTC:    {df['timestamp_utc'].max()}")
    print(f"- Años locales: {df['local_year'].min()}-{df['local_year'].max()}")

    print("\nFilas por estación antes de filtros:")
    print(df["season"].value_counts().reindex(SEASON_ORDER).to_string())

    low_demand = df[df["demand_mw"] <= LOW_DEMAND_THRESHOLD_MW].copy()

    print(f"\nValores con demanda <= {LOW_DEMAND_THRESHOLD_MW} MW: {len(low_demand):,}")
    if not low_demand.empty:
        print(low_demand[
            ["timestamp_utc", "timestamp_madrid", "season", "demand_mw", "temp_c"]
        ].head(20).to_string(index=False))

    df = df[df["demand_mw"] > LOW_DEMAND_THRESHOLD_MW].copy()

    before_inertia_filter = len(df)
    df = df.dropna(subset=["temp_lag_24h", "temp_mean_24h_prev"]).copy()
    after_inertia_filter = len(df)

    print(f"\nFilas tras filtrar demanda baja: {before_inertia_filter:,}")
    print(f"Filas tras eliminar NaN de inercia térmica: {after_inertia_filter:,}")

    print("\nFestivos nacionales detectados por estación:")
    holidays_detected = (
        df[df["is_holiday_es"] == 1]
        [["local_date", "season", "holiday_name"]]
        .drop_duplicates()
        .sort_values(["local_date", "season"])
    )
    print(holidays_detected.head(80).to_string(index=False))

    model_functions = {
        "baseline_poly2_calendar_holiday": fit_predict_baseline_poly2,
        "gam_additive_calendar_holiday": fit_predict_gam_additive,
        "gam_temp_hour_interaction_calendar_holiday": fit_predict_gam_temp_hour_interaction,
        "gam_temp_hour_interaction_inertia_holiday": fit_predict_gam_temp_hour_interaction_inertia,
    }

    metrics_records = []
    prediction_frames = []

    for season in SEASON_ORDER:
        print("\n" + "=" * 100)
        print(f"ESTACIÓN: {season} - {SEASON_NAMES[season]}")
        print("=" * 100)

        df_season = df[df["season"] == season].copy()

        train = df_season[df_season["local_year"] <= TRAIN_END_YEAR].copy()
        test = df_season[df_season["local_year"] >= TEST_START_YEAR].copy()

        print(f"Train: <= {TRAIN_END_YEAR} | filas: {len(train):,}")
        print(f"Test:  >= {TEST_START_YEAR} | filas: {len(test):,}")

        if train.empty or test.empty:
            print(f"AVISO: estación {season} sin train o test. Se omite.")
            continue

        for model_name, model_func in model_functions.items():
            print(f"\nAjustando modelo: {model_name}")

            try:
                pred_train, pred_test = model_func(train, test)

                metrics = evaluate_model(
                    season=season,
                    model_name=model_name,
                    train=train,
                    test=test,
                    pred_train=pred_train,
                    pred_test=pred_test,
                )

                metrics_records.append(metrics)

                pred_frame = build_prediction_frame(
                    season=season,
                    model_name=model_name,
                    test=test,
                    pred_test=pred_test,
                )

                prediction_frames.append(pred_frame)

                print(
                    f"OK | R² test={metrics['r2_test']:.4f} | "
                    f"RMSE test={metrics['rmse_test_mw']:.1f} MW | "
                    f"MAE test={metrics['mae_test_mw']:.1f} MW"
                )

            except Exception as e:
                print(f"ERROR en modelo {model_name} para estación {season}: {e}")

    if not metrics_records:
        raise RuntimeError("No se ha podido ajustar ningún modelo.")

    metrics_df = pd.DataFrame(metrics_records)

    metrics_df["valid_physical"] = (
        (metrics_df["n_pred_negative"] == 0)
        & (metrics_df["n_pred_below_10000"] == 0)
        & (metrics_df["n_pred_above_50000"] == 0)
    )

    metrics_df["season"] = pd.Categorical(
        metrics_df["season"],
        categories=SEASON_ORDER,
        ordered=True,
    )

    metrics_df = metrics_df.sort_values(["season", "rmse_test_mw"]).reset_index(drop=True)

    pred_df = pd.concat(prediction_frames, ignore_index=True)

    # ------------------------------------------------------------
    # Mejor modelo por estación
    # Primero elegimos entre modelos físicamente válidos.
    # Si ninguno es válido, elegimos el de menor RMSE igualmente,
    # pero quedará marcado como no válido.
    # ------------------------------------------------------------

    best_rows = []

    for season in SEASON_ORDER:
        subset = metrics_df[metrics_df["season"] == season].copy()

        if subset.empty:
            continue

        subset_valid = subset[subset["valid_physical"] == True].copy()

        if not subset_valid.empty:
            best = subset_valid.sort_values("rmse_test_mw").iloc[0]
        else:
            best = subset.sort_values("rmse_test_mw").iloc[0]

        best_rows.append(best)

    best_df = pd.DataFrame(best_rows)

    best_models = dict(zip(best_df["season"].astype(str), best_df["model"]))

    pred_df["best_model_for_season"] = pred_df["season"].map(best_models)
    pred_best = pred_df[pred_df["model"] == pred_df["best_model_for_season"]].copy()

    # ------------------------------------------------------------
    # Mejoras respecto al modelo base
    # ------------------------------------------------------------

    improvements = []

    for season in SEASON_ORDER:
        subset = metrics_df[metrics_df["season"] == season].copy()

        if subset.empty:
            continue

        base = subset[subset["model"] == "baseline_poly2_calendar_holiday"]
        best = best_df[best_df["season"].astype(str) == season]

        if base.empty or best.empty:
            continue

        base = base.iloc[0]
        best = best.iloc[0]

        improvements.append({
            "season": season,
            "season_name": SEASON_NAMES[season],
            "best_model": best["model"],
            "base_rmse_test_mw": base["rmse_test_mw"],
            "best_rmse_test_mw": best["rmse_test_mw"],
            "delta_rmse_test_mw_best_vs_base": best["rmse_test_mw"] - base["rmse_test_mw"],
            "base_mae_test_mw": base["mae_test_mw"],
            "best_mae_test_mw": best["mae_test_mw"],
            "delta_mae_test_mw_best_vs_base": best["mae_test_mw"] - base["mae_test_mw"],
            "base_r2_test": base["r2_test"],
            "best_r2_test": best["r2_test"],
            "delta_r2_test_best_vs_base": best["r2_test"] - base["r2_test"],
            "best_valid_physical": best["valid_physical"],
        })

    improvements_df = pd.DataFrame(improvements)

    # ------------------------------------------------------------
    # Diagnósticos del mejor modelo
    # ------------------------------------------------------------

    pred_best["temp_bin_c"] = pred_best["temp_c"].round().astype(int)

    summary_by_season = summarize_group(pred_best, ["season"])
    summary_by_year = summarize_group(pred_best, ["season", "local_year"])
    summary_by_month = summarize_group(pred_best, ["season", "year_month"])
    summary_by_local_month = summarize_group(pred_best, ["season", "local_month"])
    summary_by_hour = summarize_group(pred_best, ["season", "local_hour"])
    summary_by_dow = summarize_group(pred_best, ["season", "local_day_of_week"])
    summary_by_holiday = summarize_group(pred_best, ["season", "is_holiday_es"])
    summary_by_temp_bin = summarize_group(pred_best, ["season", "temp_bin_c"])

    # ------------------------------------------------------------
    # Guardar resultados
    # ------------------------------------------------------------

    metrics_path = OUT_DIR / "22_metrics_all_models_by_season.csv"
    best_path = OUT_DIR / "22_best_model_by_season.csv"
    improvements_path = OUT_DIR / "22_improvements_best_vs_baseline.csv"
    predictions_path = OUT_DIR / "22_test_predictions_all_models.csv"
    predictions_best_path = OUT_DIR / "22_test_predictions_best_model_by_season.csv"

    metrics_df.to_csv(metrics_path, index=False)
    best_df.to_csv(best_path, index=False)
    improvements_df.to_csv(improvements_path, index=False)
    pred_df.to_csv(predictions_path, index=False)
    pred_best.to_csv(predictions_best_path, index=False)

    summary_by_season.to_csv(OUT_DIR / "22_error_summary_best_by_season.csv", index=False)
    summary_by_year.to_csv(OUT_DIR / "22_error_summary_best_by_year.csv", index=False)
    summary_by_month.to_csv(OUT_DIR / "22_error_summary_best_by_month.csv", index=False)
    summary_by_local_month.to_csv(OUT_DIR / "22_error_summary_best_by_local_month.csv", index=False)
    summary_by_hour.to_csv(OUT_DIR / "22_error_summary_best_by_hour.csv", index=False)
    summary_by_dow.to_csv(OUT_DIR / "22_error_summary_best_by_day_of_week.csv", index=False)
    summary_by_holiday.to_csv(OUT_DIR / "22_error_summary_best_by_holiday.csv", index=False)
    summary_by_temp_bin.to_csv(OUT_DIR / "22_error_summary_best_by_temp_bin.csv", index=False)

    # ------------------------------------------------------------
    # Gráficos
    # ------------------------------------------------------------

    plot_metric_comparison(metrics_df)
    plot_best_monthly(pred_best)
    plot_best_scatter(pred_best)

    # ------------------------------------------------------------
    # Impresión final
    # ------------------------------------------------------------

    print("\n" + "=" * 100)
    print("RESUMEN GLOBAL DE MODELOS POR ESTACIÓN")
    print("=" * 100)

    cols_metrics = [
        "season",
        "model",
        "valid_physical",
        "r2_train",
        "r2_test",
        "rmse_train_mw",
        "rmse_test_mw",
        "mae_train_mw",
        "mae_test_mw",
        "bias_test_mw",
        "n_pred_negative",
        "n_pred_below_10000",
        "n_pred_above_50000",
    ]

    safe_print_df(metrics_df[cols_metrics], max_rows=100)

    print("\n" + "=" * 100)
    print("MEJOR MODELO POR ESTACIÓN")
    print("=" * 100)

    cols_best = [
        "season",
        "model",
        "valid_physical",
        "r2_test",
        "rmse_test_mw",
        "mae_test_mw",
        "bias_test_mw",
        "p90_abs_error_test_mw",
        "pred_min",
        "pred_max",
    ]

    safe_print_df(best_df[cols_best], max_rows=100)

    print("\n" + "=" * 100)
    print("MEJORA DEL MEJOR MODELO RESPECTO AL MODELO BASE")
    print("=" * 100)

    safe_print_df(improvements_df, max_rows=100)

    print("\n" + "=" * 100)
    print("ARCHIVOS GENERADOS")
    print("=" * 100)

    print(f"- Métricas todos los modelos: {metrics_path}")
    print(f"- Mejor modelo por estación: {best_path}")
    print(f"- Mejoras respecto al base: {improvements_path}")
    print(f"- Predicciones test todos los modelos: {predictions_path}")
    print(f"- Predicciones test mejores modelos: {predictions_best_path}")
    print(f"- Resúmenes de error: {OUT_DIR}")
    print(f"- Gráficos: {PLOTS_DIR}")

    print("\nScript finalizado correctamente.")


