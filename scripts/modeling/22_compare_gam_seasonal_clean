def plot_metric_comparison(metrics_df):
    metrics_plot = metrics_df.copy()
    metrics_plot["season"] = pd.Categorical(
        metrics_plot["season"],
        categories=SEASON_ORDER,
        ordered=True,
    )
    metrics_plot = metrics_plot.sort_values(["season", "model"])

    for metric, ylabel, filename in [
        ("rmse_test_mw", "RMSE test (MW)", "01_rmse_test_by_season_model.png"),
        ("mae_test_mw", "MAE test (MW)", "02_mae_test_by_season_model.png"),
        ("r2_test", "R² test", "03_r2_test_by_season_model.png"),
    ]:
        pivot = metrics_plot.pivot(index="season", columns="model", values=metric)
        pivot = pivot.loc[[s for s in SEASON_ORDER if s in pivot.index]]

        ax = pivot.plot(kind="bar", figsize=(12, 6))
        ax.set_title(f"Comparación de modelos por estación - {ylabel}")
        ax.set_xlabel("Estación")
        ax.set_ylabel(ylabel)
        ax.grid(True, alpha=0.3)
        plt.xticks(rotation=0)
        plt.tight_layout()
        plt.savefig(PLOTS_DIR / filename, dpi=150)
        plt.close()


def plot_best_monthly(pred_best):
    monthly = summarize_group(
        pred_best,
        ["season", "year_month"],
    )

    for season in SEASON_ORDER:
        data = monthly[monthly["season"] == season].copy()
        if data.empty:
            continue

        plt.figure(figsize=(12, 5))
        plt.plot(data["year_month"], data["observed_mean_mw"], marker="o", label="Observado")
        plt.plot(data["year_month"], data["predicted_mean_mw"], marker="o", label="Predicho")
        plt.title(f"{SEASON_NAMES[season]} test 2021-2025: observado vs predicho")
        plt.xlabel("Mes")
        plt.ylabel("Demanda media (MW)")
        plt.xticks(rotation=45)
        plt.grid(True, alpha=0.3)
        plt.legend()
        plt.tight_layout()
        plt.savefig(PLOTS_DIR / f"04_best_model_monthly_{season}.png", dpi=150)
        plt.close()


def plot_best_scatter(pred_best):
    for season in SEASON_ORDER:
        data = pred_best[pred_best["season"] == season].copy()
        if data.empty:
            continue

        min_value = min(data["observed_mw"].min(), data["predicted_mw"].min())
        max_value = max(data["observed_mw"].max(), data["predicted_mw"].max())

        plt.figure(figsize=(7, 7))
        plt.scatter(data["observed_mw"], data["predicted_mw"], alpha=0.25, s=8)
        plt.plot([min_value, max_value], [min_value, max_value])
        plt.title(f"{SEASON_NAMES[season]}: observado vs predicho")
        plt.xlabel("Demanda observada (MW)")
        plt.ylabel("Demanda predicha (MW)")
        plt.grid(True, alpha=0.3)
        plt.tight_layout()
        plt.savefig(PLOTS_DIR / f"05_best_model_scatter_{season}.png", dpi=150)
        plt.close()


