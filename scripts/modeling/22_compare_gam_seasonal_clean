# MODELOS GAM
# ============================================================

def fit_predict_gam_additive(train, test):
    """
    GAM aditivo:
    demanda = s(temp) + hora + día semana + mes + festivo
    """
    feature_cols = [
        "temp_c",
        "local_hour",
        "local_day_of_week",
        "local_month",
        "is_holiday_es",
    ]

    X_train = train[feature_cols].to_numpy(dtype=float)
    X_test = test[feature_cols].to_numpy(dtype=float)

    y_train = train["demand_mw"].to_numpy(dtype=float)

    gam = LinearGAM(
        s(0, n_splines=12)
        + f(1)
        + f(2)
        + f(3)
        + f(4),
        max_iter=300,
    )

    gam.fit(X_train, y_train)

    pred_train = gam.predict(X_train)
    pred_test = gam.predict(X_test)

    return pred_train, pred_test


def fit_predict_gam_temp_hour_interaction(train, test):
    """
    GAM con interacción temperatura-hora:
    demanda = s(temp) + hora + te(temp, hora) + día semana + mes + festivo
    """
    feature_cols = [
        "temp_c",
        "local_hour",
        "local_day_of_week",
        "local_month",
        "is_holiday_es",
    ]

    X_train = train[feature_cols].to_numpy(dtype=float)
    X_test = test[feature_cols].to_numpy(dtype=float)

    y_train = train["demand_mw"].to_numpy(dtype=float)

    gam = LinearGAM(
        s(0, n_splines=12)
        + f(1)
        + te(0, 1, n_splines=[12, 8])
        + f(2)
        + f(3)
        + f(4),
        max_iter=300,
    )

    gam.fit(X_train, y_train)

    pred_train = gam.predict(X_train)
    pred_test = gam.predict(X_test)

    return pred_train, pred_test


def fit_predict_gam_temp_hour_interaction_inertia(train, test):
    """
    GAM con interacción temperatura-hora + inercia térmica:
    demanda = s(temp) + hora + te(temp, hora)
              + s(temp_lag_24h) + s(temp_mean_24h_prev)
              + día semana + mes + festivo
    """
    feature_cols = [
        "temp_c",
        "local_hour",
        "temp_lag_24h",
        "temp_mean_24h_prev",
        "local_day_of_week",
        "local_month",
        "is_holiday_es",
    ]

    X_train = train[feature_cols].to_numpy(dtype=float)
    X_test = test[feature_cols].to_numpy(dtype=float)

    y_train = train["demand_mw"].to_numpy(dtype=float)

    gam = LinearGAM(
        s(0, n_splines=12)
        + f(1)
        + te(0, 1, n_splines=[12, 8])
        + s(2, n_splines=10)
        + s(3, n_splines=10)
        + f(4)
        + f(5)
        + f(6),
        max_iter=300,
    )

    gam.fit(X_train, y_train)

    pred_train = gam.predict(X_train)
    pred_test = gam.predict(X_test)

    return pred_train, pred_test


# ============================================================
# EVALUACIÓN
# ============================================================

def evaluate_model(season, model_name, train, test, pred_train, pred_test):
    y_train = train["demand_mw"].to_numpy(dtype=float)
    y_test = test["demand_mw"].to_numpy(dtype=float)

    residual_test = y_test - pred_test
    abs_error_test = np.abs(residual_test)

    return {
        "season": season,
        "season_name": SEASON_NAMES.get(season, season),
        "model": model_name,

        "n_train": len(train),
        "n_test": len(test),

        "r2_train": r2_score_manual(y_train, pred_train),
        "r2_test": r2_score_manual(y_test, pred_test),

        "rmse_train_mw": rmse(y_train, pred_train),
        "rmse_test_mw": rmse(y_test, pred_test),

        "mae_train_mw": mae(y_train, pred_train),
        "mae_test_mw": mae(y_test, pred_test),

        "bias_test_mw": np.mean(residual_test),
        "median_abs_error_test_mw": np.median(abs_error_test),
        "p90_abs_error_test_mw": np.percentile(abs_error_test, 90),
        "max_abs_error_test_mw": np.max(abs_error_test),

        "pred_min": np.min(pred_test),
        "pred_p01": np.percentile(pred_test, 1),
        "pred_mean": np.mean(pred_test),
        "pred_p99": np.percentile(pred_test, 99),
        "pred_max": np.max(pred_test),

        "obs_min": np.min(y_test),
        "obs_mean": np.mean(y_test),
        "obs_max": np.max(y_test),

        "n_pred_negative": int(np.sum(pred_test < 0)),
        "n_pred_below_10000": int(np.sum(pred_test < 10000)),
        "n_pred_above_50000": int(np.sum(pred_test > 50000)),
        "n_pred_above_70000": int(np.sum(pred_test > 70000)),
    }


def build_prediction_frame(season, model_name, test, pred_test):
    out = test[
        [
            "timestamp_utc",
            "timestamp_madrid",
            "local_year",
            "year_month",
            "local_month",
            "local_hour",
            "local_day_of_week",
            "local_date",
            "season",
            "temp_c",
            "temp_lag_24h",
            "temp_mean_24h_prev",
            "is_weekend",
            "is_holiday_es",
            "holiday_name",
            "demand_mw",
        ]
    ].copy()

    out["model"] = model_name
    out["observed_mw"] = out["demand_mw"]
    out["predicted_mw"] = pred_test
    out["residual_mw"] = out["observed_mw"] - out["predicted_mw"]
    out["abs_error_mw"] = np.abs(out["residual_mw"])

    return out


def summarize_group(df, group_cols):
    def calc(g):
        return pd.Series({
            "n_obs": len(g),
            "observed_mean_mw": g["observed_mw"].mean(),
            "predicted_mean_mw": g["predicted_mw"].mean(),
            "bias_mean_mw": g["residual_mw"].mean(),
            "mae_mw": g["abs_error_mw"].mean(),
            "median_abs_error_mw": g["abs_error_mw"].median(),
            "p90_abs_error_mw": g["abs_error_mw"].quantile(0.90),
            "rmse_mw": rmse(g["observed_mw"], g["predicted_mw"]),
        })

    return df.groupby(group_cols, dropna=False).apply(calc).reset_index()


