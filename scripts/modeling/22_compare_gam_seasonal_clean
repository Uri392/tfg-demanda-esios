def rmse(y_true, y_pred):
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)
    return np.sqrt(np.mean((y_true - y_pred) ** 2))


def mae(y_true, y_pred):
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)
    return np.mean(np.abs(y_true - y_pred))


def r2_score_manual(y_true, y_pred):
    y_true = np.asarray(y_true)
    y_pred = np.asarray(y_pred)

    ss_res = np.sum((y_true - y_pred) ** 2)
    ss_tot = np.sum((y_true - np.mean(y_true)) ** 2)

    if ss_tot == 0:
        return np.nan

    return 1 - ss_res / ss_tot


def safe_print_df(df, title=None, max_rows=50):
    if title:
        print("\n" + title)
        print("-" * len(title))

    if df.empty:
        print("(vacío)")
    else:
        print(df.head(max_rows).to_string(index=False))


# ============================================================
# LECTURA DE BASE DE DATOS
# ============================================================

def get_tables(conn):
    query = """
        SELECT name
        FROM sqlite_master
        WHERE type = 'table'
        ORDER BY name
    """
    return pd.read_sql_query(query, conn)["name"].tolist()


def require_table(tables, expected_name):
    if expected_name not in tables:
        raise ValueError(
            f"No se ha encontrado la tabla esperada: {expected_name}\n"
            f"Tablas disponibles: {tables}"
        )


def load_data():
    if not DB_PATH.exists():
        raise FileNotFoundError(f"No existe la base de datos: {DB_PATH}")

    conn = sqlite3.connect(DB_PATH)

    tables = get_tables(conn)

    print("Tablas encontradas en la base de datos:")
    for t in tables:
        print(f"- {t}")

    require_table(tables, "demand_peninsula_hourly")
    require_table(tables, "temperature_peninsula_hourly")

    demand = pd.read_sql_query(
        """
        SELECT timestamp_utc, demand_mw
        FROM demand_peninsula_hourly
        """,
        conn,
    )

    temp = pd.read_sql_query(
        """
        SELECT timestamp_utc, temp_c
        FROM temperature_peninsula_hourly
        """,
        conn,
    )

    conn.close()

    demand["timestamp_utc"] = pd.to_datetime(demand["timestamp_utc"], utc=True, errors="coerce")
    temp["timestamp_utc"] = pd.to_datetime(temp["timestamp_utc"], utc=True, errors="coerce")

    demand["demand_mw"] = pd.to_numeric(demand["demand_mw"], errors="coerce")
    temp["temp_c"] = pd.to_numeric(temp["temp_c"], errors="coerce")

    demand = demand.dropna(subset=["timestamp_utc", "demand_mw"])
    temp = temp.dropna(subset=["timestamp_utc", "temp_c"])

    demand = (
        demand
        .groupby("timestamp_utc", as_index=False)["demand_mw"]
        .mean()
    )

    temp = (
        temp
        .groupby("timestamp_utc", as_index=False)["temp_c"]
        .mean()
    )

    df = demand.merge(temp, on="timestamp_utc", how="inner")
    df = df.sort_values("timestamp_utc").reset_index(drop=True)

    print(f"\nFilas leídas tras unir demanda y temperatura: {len(df):,}")

    return df


