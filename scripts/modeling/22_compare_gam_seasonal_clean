# VARIABLES DE CALENDARIO Y FESTIVOS
# ============================================================

def build_manual_holidays(years):
    """
    Festivos nacionales básicos fijos.
    Se añaden manualmente para evitar problemas de cobertura histórica
    de algunas librerías, especialmente en años antiguos.
    """
    manual = {}

    fixed_holidays = [
        (1, 1, "Año Nuevo"),
        (1, 6, "Epifanía del Señor"),
        (5, 1, "Fiesta del Trabajo"),
        (8, 15, "Asunción de la Virgen"),
        (10, 12, "Fiesta Nacional de España"),
        (11, 1, "Todos los Santos"),
        (12, 6, "Día de la Constitución"),
        (12, 8, "Inmaculada Concepción"),
        (12, 25, "Navidad"),
    ]

    for year in years:
        for month, day, name in fixed_holidays:
            date_value = pd.Timestamp(year=year, month=month, day=day).date()
            manual[date_value] = name

    return manual


def add_calendar_features(df):
    df = df.copy()

    df["timestamp_madrid"] = df["timestamp_utc"].dt.tz_convert("Europe/Madrid")

    df["local_year"] = df["timestamp_madrid"].dt.year
    df["local_month"] = df["timestamp_madrid"].dt.month
    df["local_hour"] = df["timestamp_madrid"].dt.hour
    df["local_day_of_week"] = df["timestamp_madrid"].dt.dayofweek  # lunes=0, domingo=6
    df["local_date"] = df["timestamp_madrid"].dt.date
    df["year_month"] = df["timestamp_madrid"].dt.strftime("%Y-%m")

    df["is_weekend"] = df["local_day_of_week"].isin([5, 6]).astype(int)

    conditions = [
        df["local_month"].isin([12, 1, 2]),
        df["local_month"].isin([3, 4, 5]),
        df["local_month"].isin([6, 7, 8]),
        df["local_month"].isin([9, 10, 11]),
    ]

    choices = ["DJF", "MAM", "JJA", "SON"]

    df["season"] = np.select(conditions, choices, default="UNKNOWN")

    years = range(int(df["local_year"].min()), int(df["local_year"].max()) + 1)

    manual_holidays = build_manual_holidays(years)

    if holidays is not None:
        es_holidays = holidays.Spain(years=years)
    else:
        es_holidays = {}

    def is_spanish_holiday(date_value):
        return int((date_value in es_holidays) or (date_value in manual_holidays))

    def get_spanish_holiday_name(date_value):
        if date_value in es_holidays:
            return str(es_holidays.get(date_value))
        if date_value in manual_holidays:
            return manual_holidays.get(date_value)
        return ""

    df["is_holiday_es"] = df["local_date"].apply(is_spanish_holiday).astype(int)
    df["holiday_name"] = df["local_date"].apply(get_spanish_holiday_name)

    df["is_non_working_day_basic"] = (
        (df["is_weekend"] == 1) | (df["is_holiday_es"] == 1)
    ).astype(int)

    return df


# ============================================================
# VARIABLES DE INERCIA TÉRMICA
# ============================================================

def add_thermal_inertia_features(df):
    """
    Calculamos la inercia antes de filtrar por estación.
    Así una hora de junio puede usar temperatura previa de mayo si corresponde.
    """
    df = df.copy()
    df = df.sort_values("timestamp_utc").reset_index(drop=True)

    df["temp_lag_24h"] = df["temp_c"].shift(24)
    df["temp_mean_24h_prev"] = df["temp_c"].rolling(window=24, min_periods=24).mean().shift(1)
    df["temp_mean_6h_prev"] = df["temp_c"].rolling(window=6, min_periods=6).mean().shift(1)

    return df


# ============================================================
# MODELO BASE LINEAL / POLINÓMICO
# ============================================================

def fit_predict_baseline_poly2(train, test):
    """
    Modelo base defendible:
    demanda = temp + temp^2 + hora + día semana + mes + fin de semana + festivo

    Se estima con mínimos cuadrados usando numpy para evitar depender de sklearn.
    """
    train = train.copy()
    test = test.copy()

    train["split"] = "train"
    test["split"] = "test"

    all_df = pd.concat([train, test], ignore_index=True)

    all_df["temp_sq"] = all_df["temp_c"] ** 2

    categorical_cols = [
        "local_hour",
        "local_day_of_week",
        "local_month",
    ]

    numeric_cols = [
        "temp_c",
        "temp_sq",
        "is_weekend",
        "is_holiday_es",
    ]

    X_num = all_df[numeric_cols].astype(float)

    X_cat = pd.get_dummies(
        all_df[categorical_cols].astype(str),
        columns=categorical_cols,
        drop_first=True,
        dtype=float,
    )

    X = pd.concat([X_num, X_cat], axis=1)

    X.insert(0, "intercept", 1.0)

    X_train = X.loc[all_df["split"] == "train"].to_numpy(dtype=float)
    X_test = X.loc[all_df["split"] == "test"].to_numpy(dtype=float)

    y_train = train["demand_mw"].to_numpy(dtype=float)

    beta, *_ = np.linalg.lstsq(X_train, y_train, rcond=None)

    pred_train = X_train @ beta
    pred_test = X_test @ beta

    return pred_train, pred_test


