from pathlib import Path
from urllib.request import Request, urlopen
import unicodedata

import pandas as pd


# =========================
# CONFIGURACIÓN
# =========================

OUT_DIR = Path("data/external/macro")
OUT_DIR.mkdir(parents=True, exist_ok=True)

REPORT_DIR = Path("outputs/macro")
REPORT_DIR.mkdir(parents=True, exist_ok=True)

XLSX_PATH = OUT_DIR / "miteco_webtabla_inv_ed2026.xlsx"
REPORT_PATH = REPORT_DIR / "co2_miteco_excel_inspection.txt"

# Tabla resumen de emisiones. Edición 2026 del Inventario Nacional GEI.
# Serie 1990-2024.
MITECO_XLSX_URL = (
    "https://www.miteco.gob.es/content/dam/miteco/es/"
    "calidad-y-evaluacion-ambiental/temas/sistema-espanol-de-inventario-sei-/"
    "webtabla-inv-Ed2026.xlsx"
)


def normalize_text(value):
    """
    Normaliza texto para buscar CO2, CO₂, total, etc.
    """
    if pd.isna(value):
        return ""

    text = str(value).strip().lower()

    # Quitar tildes
    text = unicodedata.normalize("NFKD", text)
    text = "".join(c for c in text if not unicodedata.combining(c))

    # Normalizar subíndices frecuentes
    text = text.replace("₂", "2")

    return text


def download_file_if_needed():
    if XLSX_PATH.exists():
        print(f"El archivo ya existe, no se descarga de nuevo: {XLSX_PATH}")
        return

    print("Descargando Excel de MITECO...")
    print(MITECO_XLSX_URL)

    request = Request(
        MITECO_XLSX_URL,
        headers={
            "User-Agent": (
                "Mozilla/5.0 (Windows NT 10.0; Win64; x64) "
                "AppleWebKit/537.36"
            )
        },
    )

    with urlopen(request, timeout=120) as response:
        content = response.read()

    XLSX_PATH.write_bytes(content)

    print(f"Archivo descargado correctamente: {XLSX_PATH}")
    print(f"Tamaño: {XLSX_PATH.stat().st_size / 1024 / 1024:.2f} MB")


def inspect_workbook():
    print("\nLeyendo estructura del Excel...")

    xls = pd.ExcelFile(XLSX_PATH)

    lines = []
    lines.append("INSPECCIÓN EXCEL MITECO - INVENTARIO GEI EDICIÓN 2026")
    lines.append("=" * 80)
    lines.append(f"Archivo: {XLSX_PATH}")
    lines.append("")
    lines.append("Hojas encontradas:")
    for sheet in xls.sheet_names:
        lines.append(f"- {sheet}")

    lines.append("")
    lines.append("=" * 80)
    lines.append("BÚSQUEDA DE TÉRMINOS CLAVE")
    lines.append("=" * 80)

    keywords = [
        "co2",
        "dioxido",
        "carbono",
        "total",
        "gei",
        "greenhouse",
        "emisiones",
        "emision",
        "kt",
        "kilotoneladas",
    ]

    for sheet in xls.sheet_names:
        lines.append("")
        lines.append("-" * 80)
        lines.append(f"HOJA: {sheet}")
        lines.append("-" * 80)

        try:
            df = pd.read_excel(
                XLSX_PATH,
                sheet_name=sheet,
                header=None,
                dtype=object,
                nrows=120,
            )
        except Exception as e:
            lines.append(f"No se pudo leer la hoja. Error: {e}")
            continue

        lines.append(f"Dimensión leída parcialmente: {df.shape[0]} filas x {df.shape[1]} columnas")

        # Buscar celdas con términos clave
        matches = []

        for row_idx in range(df.shape[0]):
            for col_idx in range(df.shape[1]):
                value = df.iat[row_idx, col_idx]
                text = normalize_text(value)

                if any(keyword in text for keyword in keywords):
                    matches.append((row_idx, col_idx, value))

        if not matches:
            lines.append("No se encontraron términos clave en las primeras 120 filas.")
        else:
            lines.append(f"Coincidencias encontradas: {len(matches)}")
            lines.append("Primeras 40 coincidencias:")
            for row_idx, col_idx, value in matches[:40]:
                lines.append(f"  fila={row_idx}, col={col_idx}, valor={repr(value)}")

        # Imprimir una vista previa de las primeras filas no vacías
        lines.append("")
        lines.append("Vista previa de primeras filas con contenido:")
        non_empty_rows = df.dropna(how="all").head(25)

        if non_empty_rows.empty:
            lines.append("La hoja parece vacía en las primeras 120 filas.")
        else:
            preview = non_empty_rows.to_string(index=True, max_cols=12)
            lines.append(preview)

    REPORT_PATH.write_text("\n".join(lines), encoding="utf-8")

    print(f"\nInforme de inspección guardado en:")
    print(REPORT_PATH)

    print("\nResumen rápido:")
    print("Hojas encontradas:")
    for sheet in xls.sheet_names:
        print(f"- {sheet}")

    print("\nAhora abre o pega el contenido relevante de:")
    print(REPORT_PATH)


def main():
    download_file_if_needed()
    inspect_workbook()


if __name__ == "__main__":
    main()